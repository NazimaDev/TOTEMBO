# Serverga yuklaganingizda bu faylni .env deb nusxalang va qiymatlarni to'ldiring.
# Masalan: cp .env.example .env
# .env faylini Git ga commit qilmang!

# Django maxfiy kalit (obligatoriy serverda). Yangi kalit: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Production uchun False
DJANGO_DEBUG=False

# Server domeningiz (vergul bilan ajratib)
# Masalan: totembo.com,www.totembo.com
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# HTTPS bo'lgan domenlaringiz (vergul bilan)
# Masalan: https://totembo.com,https://www.totembo.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
